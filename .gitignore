# ======================
# ENV / PYTHON
# ======================
.venv/
__pycache__/
*.pyc
*.pyo

# ======================
# DATA (raw / sensitive)
# ======================
data/
*.csv

# ======================
# MODELS
# ✅ อนุญาต model ที่ใช้ deploy
# ======================
# ignore model อื่น ๆ (optional)
# models/

# ❗ allow model ที่ใช้ใน app
!src/models/saved_models/
!src/models/saved_models/**
!*.joblib
!*.pkl

# ======================
# REPORTS / FIGURES
# ======================
# ignore output อื่น
reports/

# ❗ allow SHAP / important figures
!src/reports/figures/
!src/reports/figures/**
!*.png
!*.jpg

# ======================
# CATBOOST
# ======================
catboost_info/

# ======================
# LOGS
# ======================
*.log
*.tmp

# ======================
# SECRETS
# ======================
.env

# ======================
# MISC
# ======================
.ipynb_checkpoints/
.DS_Store
Thumbs.db